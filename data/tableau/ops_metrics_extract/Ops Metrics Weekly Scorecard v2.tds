        <connection authentication='sqlserver' class='sqlserver' dbname='' minimum-driver-version='SQL Server Native Client 10.0' odbc-connect-string-extras='ApplicationIntent=ReadOnly' odbc-native-protocol='yes' one-time-sql='' server='NDCSQLCLUS04' server-oauth='' username='svc_bisandbox_read_prod' workgroup-auth-mode='prompt'>
