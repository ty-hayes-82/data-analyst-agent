  <aliases enabled='yes' />
  <column caption='truck_count_header' datatype='string' name='[01 - Header (copy)]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='&apos;Truck Count&apos;' />
  </column>
  <column caption='deadhead_%_header' datatype='string' name='[10 - Header (copy 2)]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='&apos;Deadhead %&apos;' />
  </column>
  <column caption='miles_per_truck_header' datatype='string' name='[10 - Header (copy)]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='&apos;Loaded Miles/Trk/Wk&apos;' />
  </column>
  <column caption='Filter Out Current Week' datatype='boolean' datatype-customized='true' hidden='true' name='[13 Week Filter (copy)]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;, [cal_dt (copy)]) &lt; DATETRUNC(&apos;week&apos;, [Calculation_650207229401407488])' />
  </column>
  <column caption='loaded_miles_chart' datatype='real' default-format='n#,##0;(#,##0)' hidden='true' name='[2 - Chart (copy)]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='WINDOW_SUM(SUM([ld_mi_less_swift_billto (copy)]), -6, 0)'>
      <table-calc ordering-type='Rows' />
    </calculation>
  </column>
  <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
    <aliases>
      <alias key='&quot;[Ops Metrics Weekly Scorecard v2].[usr:Revenue xFuel Per Day (copy):qk]&quot;' value='Rev/Trk/Wk' />
      <alias key='&quot;[Ops Metrics Weekly Scorecard v2].[win:usr:Calculation_1545860622406541316:qk:6]&quot;' value='Avg Trucks Per Week' />
      <alias key='&quot;[Ops Metrics Weekly Scorecard v2].[win:usr:Revenue xFuel Per Day (copy):qk:4]&quot;' value='Revenue Per Truck Per Week' />
    </aliases>
  </column>
  <column caption='Avg Driver Count ' datatype='real' default-format='n#,##0.0;-#,##0.0' hidden='true' name='[Avg Truck Count  (copy)]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='WINDOW_SUM(SUM([drvr_cnt (copy)]))/[Calculation_315533513974996992]'>
      <table-calc ordering-type='Rows' />
    </calculation>
  </column>
  <column caption='Avg Driver Count' datatype='real' default-format='n#,##0.0;-#,##0.0' hidden='true' name='[Avg Truck Count (copy 2)]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='WINDOW_SUM(SUM([drvr_cnt (copy)]))/WINDOW_SUM(SUM([Calendar Day Count CY (copy 2)]))'>
      <table-calc ordering-type='Rows' />
    </calculation>
  </column>
  <column caption='CY_PY' datatype='string' name='[CY_PY Flag (copy)]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='IF YEAR([cal_dt (copy)]) = YEAR([Calculation_650207229401407488]) THEN &apos;CY&apos;&#13;&#10;ELSEIF YEAR([cal_dt (copy)]) = YEAR([Calculation_650207229401407488])-1 THEN &apos;PY1&apos;&#13;&#10;ELSEIF YEAR([cal_dt (copy)]) = YEAR([Calculation_650207229401407488])-2 THEN &apos;PY2&apos;&#13;&#10;END' />
  </column>
  <column caption='Unmanned Trucks' datatype='real' name='[Calculation_1018657969185873920]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='[Calculation_1545860622406541316]-[Mentor Truck Count  (copy)]' />
  </column>
  <column caption='Day Count - YTD PY' datatype='integer' name='[Calculation_1024850429566763009]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='MIN(DATEPART(&apos;dayofyear&apos;, [Calculation_847521214149730319]))-1' />
  </column>
  <column caption='EFF_DT_DATASOURCE_FILTER' datatype='date' name='[Calculation_1030479925027975168]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='[cal_dt (copy)]' />
  </column>
  <column caption='EFF DATE FILTER' datatype='boolean' name='[Calculation_1030479925028139009]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='[Calculation_1030479925027975168] &lt; TODAY()&#13;&#10;AND [Calculation_1030479925027975168] &gt;= DATEADD(&apos;year&apos;,-1,DATETRUNC(&apos;year&apos;,TODAY()))' />
  </column>
  <column aggregation='Sum' caption='Placeholder' datatype='integer' hidden='true' name='[Calculation_1035265031305338880]' role='dimension' type='ordinal'>
    <calculation class='tableau' formula='1' />
  </column>
  <column caption='Driver Count incl. Surge' datatype='real' name='[Calculation_1092967370616778754]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='(sum([drvr_cnt (copy)])/7)+[sqlproxy.0tsx0h51y72v8p16ieu0s1f11h2q].[Calculation_498773688976076800]' />
  </column>
  <column caption='SUM([Driver Count Total])/7' datatype='real' name='[Calculation_1092967370620538885]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='SUM([drvr_cnt (copy)])/7' />
  </column>
  <column caption='Total Miles/Total Driver/Wk(incl. surge)' datatype='real' name='[Calculation_1092967370627010566]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='sum([Calculation_1826209697088311297])/([Calculation_1092967370616778754])' />
  </column>
  <column caption='Dedicated Driver Utilization' datatype='real' name='[Calculation_1092967371020726280]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='SUM([Calculation_1826209697088311297])/(&#13;&#10;SUM([drvr_cnt (copy)])/7)' />
  </column>
  <column caption='Dev Testing WS Filter' datatype='integer' hidden='true' name='[Calculation_1152640036602765312]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='IF [Parameters].[Parameter 8 2] = &quot;No&quot; THEN 1 Else 0 END' />
  </column>
  <column caption='Rolling Days Filter' datatype='boolean' name='[Calculation_1199646388110344192]' role='dimension' type='nominal'>
    <calculation class='tableau' formula='[cal_dt (copy)]&gt;=DATEADD(&apos;day&apos;,-[Parameters].[Parameter 1],TODAY()) and [cal_dt (copy)]&lt;= TODAY()' />
  </column>
  <column caption='Turnover %' datatype='real' default-format='p0.0%' hidden='true' name='[Calculation_1202179674786594822]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='(SUM([trmntd_drvr_cnt (copy)])-SUM([Calculation_1280148236838432770]))/SUM([drvr_cnt (copy)])*365' />
  </column>
  <column caption='revenue_xfuel_cy' datatype='real' name='[Calculation_122160170123784199]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='SUM(If [CY2] then [Revenue xFuel (copy)_122160170121601027] END)' />
  </column>
  <column caption='lrpm_cy' datatype='real' default-format='c&quot;$&quot;#,##0.000;(&quot;$&quot;#,##0.000)' name='[Calculation_122160170124070920]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='[Calculation_122160170123784199] / [Calculation_231935438672642049]' />
  </column>
  <column caption='lrpm_var' datatype='real' default-format='*0.0%;(0.0%)' name='[Calculation_122160170124640267]' role='measure' type='quantitative'>
    <calculation class='tableau' formula='([Calculation_122160170124070920] - [lrpm_cy (copy)_122160170124455946]) / [lrpm_cy (copy)_122160170124455946]' />
