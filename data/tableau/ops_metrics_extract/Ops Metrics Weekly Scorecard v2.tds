    <relation connection='sqlserver.12l95j01xixesz15a8a4x1qjvagj' name='Custom SQL Query' type='text'><![CDATA[SELECT cal_dt,
       flt_mgr_cd,
       drvr_mgr_cd,
       icc_cst_ctr_cd,
       ownr_oprtr_flg,
       gl_div_nm,
       gl_rgn_nm,
       ops_ln_of_bus_nm,
       ops_ln_of_bus_ref_nm,
       icc_cst_ctr_nm,
       last_refresh,
       drvr_2_flg,
       wk_day_cnt,
       top_gun_stdnt_flg,
	   CASE WHEN cal_dt << GETDATE() THEN cal_dt ELSE GETDATE() END AS incremental_refresh_dt,
       SUM(CASE WHEN ops_metrics.non_rev_flg <<>> 'Y' THEN ordr_cnt END) AS rev_ordr_cnt,
       SUM(exprncd_drvr_cnt) AS exprncd_drvr_cnt,
       SUM(actv_drvr_cnt) AS actv_drvr_cnt,
       SUM(trmntd_drvr_cnt) AS trmntd_drvr_cnt,
       SUM(rnstd_drvr_cnt) AS rnstd_drvr_cnt,
       SUM(mntr_drvr_cnt) AS mntr_drvr_cnt,
       SUM(stdnt_drvr_cnt) AS stdnt_drvr_cnt,
       SUM(off_dty_min) AS off_dty_min,
       SUM(slpr_min) AS slpr_min,
       SUM(drvg_min) AS drvg_min,
       SUM(on_dty_min) AS on_dty_min,
       SUM(driver_pay_ttl_paid) AS driver_pay_ttl_paid,
       SUM(truck_count) AS truck_count,
       SUM(company_truck_count) AS company_truck_count,
       SUM(oo_truck_count) AS oo_truck_count,
       SUM(inactive_truck_count) AS inactive_truck_count,
       SUM(unmanned_truck_count) AS unmanned_truck_count,
       SUM(non_operational_truck_count) AS non_operational_truck_count,
       SUM(team_truck_count) AS team_truck_count,
       SUM(mentor_truck_count) AS mentor_truck_count,
       SUM(solo_truck_count) AS solo_truck_count,
       SUM(ordr_cnt) AS ordr_cnt,
       SUM(disp_cnt) AS disp_cnt,
       SUM(ordr_miles) AS ordr_miles,
       SUM(ttl_engn_tm) AS ttl_engn_tm,
	   sum([stop_count]) as stop_count,
       SUM(cmpny_ttl_engn_tm) AS cmpny_ttl_engn_tm,
       SUM(idle_engn_tm) AS idle_engn_tm,
       SUM(cmpny_idle_engn_tm) AS cmpny_idle_engn_tm,
       SUM(drvr_engn_tm) AS drvr_engn_tm,
       SUM(cmpny_drvr_engn_tm) AS cmpny_drvr_engn_tm,
       SUM(idle_fuel_qty) AS idle_fuel_qty,
       SUM(drvng_fuel_qty) AS drvng_fuel_qty,
       SUM(ttl_fuel_qty) AS ttl_fuel_qty,
       SUM(ttl_qlcm_mi) AS ttl_qlcm_mi,
       SUM(cmpny_qlcm_mi) AS cmpny_qlcm_mi,
       SUM(cmpny_ng_qlcm_mi) AS cmpny_ng_qlcm_mi,
       SUM(ttl_trf_mi) AS ttl_trf_mi,
       SUM(ld_trf_mi) AS ld_trf_mi,
       SUM(empty_trf_mi) AS empty_trf_mi,
       SUM(ld_mi_less_swift_billto) AS ld_mi_less_swift_billto,
       SUM(empty_mi_less_swift_billto) AS empty_mi_less_swift_billto,
       SUM(dh_miles) AS dh_miles,
       SUM(reportable_service_failures) AS reportable_service_failures,
       SUM(service_failures) AS service_failures,
       SUM(lh_rev_amt) AS lh_rev_amt,
       SUM(fuel_srchrg_rev_amt) AS fuel_srchrg_rev_amt,
       SUM(acsrl_rev_amt) AS acsrl_rev_amt,
       SUM(ttl_rev_amt) AS ttl_rev_amt,
       SUM(ocrnce_cnt) AS ocrnce_cnt,
       SUM(dot_ocrnce_cnt) AS dot_ocrnce_cnt,
       SUM(prvntbl_ocrnce_cnt) AS prvntbl_ocrnce_cnt,
       AVG(sps_pts) AS sps_pts,
       SUM(ld_trf_mi+empty_trf_mi) AS dsptch_miles,
       SUM(co_dsptch_miles) AS co_dsptch_miles,
       SUM(ttl_qlcm_mi) AS tot_qualcomm_miles,
       SUM(fuel_prchd) AS fuel_prchd
FROM SANDBOX.dbo.v_ops_metrics ops_metrics
GROUP BY cal_dt,
         flt_mgr_cd,
         drvr_mgr_cd,
         icc_cst_ctr_cd,
         ownr_oprtr_flg,
         gl_div_nm,
         gl_rgn_nm,
         ops_ln_of_bus_nm,
         ops_ln_of_bus_ref_nm,
         icc_cst_ctr_nm,
         last_refresh,
         drvr_2_flg,
         wk_day_cnt,
         top_gun_stdnt_flg]]></relation>
    <refresh increment-key='[incremental_refresh_dt]' incremental-refresh-mode='subrange-incremental-refresh' incremental-updates='true' required-client-version='250'>
      <subrange-refresh period-type='week' range='6' />
    </refresh>
