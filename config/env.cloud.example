# Cloud Environment Configuration for GCP Deployment
# This file shows cloud-native configuration patterns for Vertex AI Agent Engine

# ============================================================================
# GOOGLE CLOUD PROJECT (required in cloud)
# ============================================================================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Environment (dev, staging, prod)
ENVIRONMENT=prod

# ============================================================================
# AUTHENTICATION (Cloud)
# ============================================================================
# In Vertex AI Agent Engine, authentication is handled by:
# 1. Service Account attached to the agent (preferred)
# 2. Secrets from Secret Manager (for API keys)

# API keys stored in Secret Manager:
# - google-api-key (GOOGLE_API_KEY)
# - service-account-json (GOOGLE_APPLICATION_CREDENTIALS)

# To set secrets:
# echo -n 'YOUR_API_KEY' | gcloud secrets versions add google-api-key --data-file=-
# gcloud secrets versions add service-account-json --data-file=./service-account.json

# ============================================================================
# CLOUD STORAGE PATHS (GCS)
# ============================================================================
# Datasets and outputs use Cloud Storage buckets (auto-configured by Terraform)
# Paths format: gs://bucket-name/path

# Example paths (managed by cloud_config.py):
# - Datasets: gs://PROJECT_ID-data-analyst-datasets/datasets/
# - Outputs: gs://PROJECT_ID-data-analyst-outputs/
# - Validation: gs://PROJECT_ID-data-analyst-datasets/validation/

# ============================================================================
# MODEL CONFIGURATION (Cloud)
# ============================================================================
# Models are configured per-environment in deployment/gcp/config.yaml
# Override here only for testing:

# ROOT_AGENT_MODEL=gemini-2.5-flash-exp
# MODEL_TEMPERATURE=0.0

# ============================================================================
# ANALYSIS ENGINE (same as local)
# ============================================================================
USE_CODE_INSIGHTS=true
LEGACY_LLM_ALERT_EXTRACTION=false

# ============================================================================
# PHASE LOGGING (Cloud-native)
# ============================================================================
PHASE_LOGGING_ENABLED=true
PHASE_LOG_LEVEL=INFO

# In cloud, logs go to Cloud Logging (not local files)
# PHASE_LOG_DIRECTORY is ignored — structured logs sent to stdout/stderr

PHASE_LOG_CONSOLE_FORMAT=json  # Use JSON for Cloud Logging structured logs
PHASE_LOG_TRACK_PERFORMANCE=true
PHASE_LOG_STACK_TRACES=true

# ============================================================================
# RATE LIMITING (Cloud)
# ============================================================================
# Higher limits in production (adjust based on quota)
GOOGLE_GENAI_RPM_LIMIT=60
GOOGLE_GENAI_RETRY_DELAY=3
GOOGLE_GENAI_MAX_RETRIES=5
GOOGLE_GENAI_EXPONENTIAL_BACKOFF=True
GOOGLE_GENAI_BACKOFF_MULTIPLIER=2

# ============================================================================
# TEST MODE (disabled in production)
# ============================================================================
DATA_ANALYST_TEST_MODE=false

# ============================================================================
# EXECUTIVE BRIEF CONFIGURATION
# ============================================================================
EXECUTIVE_BRIEF_DRILL_LEVELS=0
EXECUTIVE_BRIEF_MAX_SCOPE_ENTITIES=10
EXECUTIVE_BRIEF_OUTPUT_FORMAT=pdf

# ============================================================================
# CLOUD-SPECIFIC FEATURES
# ============================================================================
# Enable Cloud Trace for performance monitoring
ENABLE_CLOUD_TRACE=true

# Enable Cloud Error Reporting
ENABLE_ERROR_REPORTING=true

# Enable structured logging for Cloud Logging
STRUCTURED_LOGGING=true

# ============================================================================
# A2A SERVER (if deploying separately)
# ============================================================================
# If Tableau data agents run on separate Cloud Run service:
# A2A_BASE_URL=https://tableau-agent-HASH-uc.a.run.app
# A2A_SERVER_PORT=8080

# If using local A2A server in same container:
# A2A_BASE_URL=http://localhost:8001
# A2A_SERVER_PORT=8001
