# Data Analyst Agent Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials!

# ============================================================================
# GOOGLE CLOUD AUTHENTICATION
# ============================================================================

# === OPTION 1: Service Account (RECOMMENDED for Production) ===
# Path to your service account JSON file
# Download from: GCP Console > IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# === OPTION 2: API Key (For Testing Only - Not Recommended) ===
# Your Google API Key
# GOOGLE_API_KEY=YOUR_API_KEY_HERE

# === OPTION 3: Application Default Credentials (ADC) ===
# No configuration needed - uses gcloud CLI authentication
# Run: gcloud auth application-default login

# ============================================================================
# GOOGLE CLOUD PROJECT CONFIGURATION
# ============================================================================

# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Region (e.g., us-central1, us-east1)
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Root agent model (gemini-2.5-pro, gemini-2.5-flash-exp, etc.)
ROOT_AGENT_MODEL=gemini-2.5-pro

# Model temperature (0.0 = deterministic, 1.0 = creative)
MODEL_TEMPERATURE=0.0

# ============================================================================
# A2A SERVER CONFIGURATION (Agent-to-Agent Protocol)
# ============================================================================

# Base URL for A2A server (for Tableau data agents)
A2A_BASE_URL=http://localhost:8001

# A2A Server Port
A2A_SERVER_PORT=8001

# ============================================================================
# RATE LIMITING (for parallel execution)
# ============================================================================

# Requests per minute limit to avoid quota issues
GOOGLE_GENAI_RPM_LIMIT=30

# Retry delay in seconds
GOOGLE_GENAI_RETRY_DELAY=3

# Maximum number of retries
GOOGLE_GENAI_MAX_RETRIES=5

# Enable exponential backoff for retries
GOOGLE_GENAI_EXPONENTIAL_BACKOFF=True

# Backoff multiplier (delay = base_delay * multiplier^retry_count)
GOOGLE_GENAI_BACKOFF_MULTIPLIER=2

# ============================================================================
# TEST MODE
# ============================================================================

# Set to "true" to use CSV data instead of Tableau A2A agents
# Useful for CI/CD and testing without external dependencies
DATA_ANALYST_TEST_MODE=false

# ============================================================================
# ANALYSIS ENGINE (Spec 008 — LLM-to-Code Refactor)
# ============================================================================

# Use code-based insight card generation instead of LLM for deterministic stages:
#   - StatisticalInsightCardGenerator (replaces StatisticalInsightsAgent LLM)
#   - HierarchyInsightCardAgent (replaces HierarchyVarianceRankerAgent LLM)
#   - DrillDownDecisionFunction (replaces DrillDownDecisionAgent LLM)
#   - AlertScoringPipeline (replaces AlertScoringCoordinator LLM)
#   - RuleBasedPlanner (replaces PlannerAgent LLM)
# Set to "false" to fall back to the original LLM-based path for any of the above.
USE_CODE_INSIGHTS=true

# Re-enable the legacy LLM-based alert extraction fallback (_llm_extract_alerts_from_text).
# Only needed if extract_alerts_from_analysis() fails to produce structured alerts.
# Default "false" — the structured JSON path is reliable and this fallback is not needed.
LEGACY_LLM_ALERT_EXTRACTION=false

# ============================================================================
# PHASE LOGGING CONFIGURATION
# ============================================================================

# Enable phase-based logging for each analysis phase
PHASE_LOGGING_ENABLED=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
PHASE_LOG_LEVEL=INFO

# Directory for phase log files (relative to project root)
PHASE_LOG_DIRECTORY=logs

# Save JSON summary after each cost center analysis
PHASE_LOG_SAVE_SUMMARY=true

# Log format: simple, detailed, json
PHASE_LOG_CONSOLE_FORMAT=detailed

# Track performance metrics for each phase
PHASE_LOG_TRACK_PERFORMANCE=true

# Log stack traces on errors
PHASE_LOG_STACK_TRACES=true

# ============================================================================
# EXECUTIVE BRIEF — HIERARCHICAL SCOPED BRIEFS (Spec 032)
# ============================================================================

# How many hierarchy levels to generate executive briefs for
# 0 = network only (current behavior)
# 1 = network + Level 1 entities (e.g. regions)
# 2 = network + Level 1 + Level 2 entities (e.g. regions + terminals)
EXECUTIVE_BRIEF_DRILL_LEVELS=0

# Maximum number of scoped briefs at Level 2 (terminals can be numerous)
EXECUTIVE_BRIEF_MAX_SCOPE_ENTITIES=10

# ============================================================================
# EXECUTIVE BRIEF — OUTPUT FORMAT (Spec 033)
# ============================================================================

# Output format for executive briefs
# md   = markdown files only (legacy behavior)
# pdf  = markdown files + single combined PDF with bookmarks (default)
# both = alias for pdf
EXECUTIVE_BRIEF_OUTPUT_FORMAT=pdf
