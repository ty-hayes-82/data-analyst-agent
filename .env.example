# Data Analyst Agent Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials!

# ============================================================================
# GOOGLE CLOUD AUTHENTICATION
# ============================================================================

# === OPTION 1: Service Account (RECOMMENDED for Production) ===
# Path to your service account JSON file
# Download from: GCP Console > IAM & Admin > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# === OPTION 2: API Key (For Testing Only - Not Recommended) ===
# Your Google API Key
# GOOGLE_API_KEY=YOUR_API_KEY_HERE

# === OPTION 3: Application Default Credentials (ADC) ===
# No configuration needed - uses gcloud CLI authentication
# Run: gcloud auth application-default login

# ============================================================================
# GOOGLE CLOUD PROJECT CONFIGURATION
# ============================================================================

# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Region (e.g., us-central1, us-east1)
GOOGLE_CLOUD_LOCATION=us-central1

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Root agent model (gemini-2.5-pro, gemini-2.5-flash-exp, etc.)
ROOT_AGENT_MODEL=gemini-2.5-pro

# Model temperature (0.0 = deterministic, 1.0 = creative)
MODEL_TEMPERATURE=0.0

# ============================================================================
# A2A SERVER CONFIGURATION (Agent-to-Agent Protocol)
# ============================================================================

# Base URL for A2A server (for Tableau data agents)
A2A_BASE_URL=http://localhost:8001

# A2A Server Port
A2A_SERVER_PORT=8001

# ============================================================================
# RATE LIMITING (for parallel execution)
# ============================================================================

# Requests per minute limit to avoid quota issues
GOOGLE_GENAI_RPM_LIMIT=30

# Retry delay in seconds
GOOGLE_GENAI_RETRY_DELAY=3

# Maximum number of retries
GOOGLE_GENAI_MAX_RETRIES=5

# Enable exponential backoff for retries
GOOGLE_GENAI_EXPONENTIAL_BACKOFF=True

# Backoff multiplier (delay = base_delay * multiplier^retry_count)
GOOGLE_GENAI_BACKOFF_MULTIPLIER=2

# Maximum number of metrics/dimensions to analyze concurrently.
# 0 or negative means "no cap".
MAX_PARALLEL_METRICS=4

# Compute-phase concurrency cap (Phase A: context/planner/stats/hierarchy/alerts).
# 0 = unlimited (all targets in parallel).
MAX_PARALLEL_COMPUTE=0

# LLM-phase concurrency cap (Phase B: narrative + synthesis + persistence).
# If unset, the legacy MAX_PARALLEL_METRICS value is used.
MAX_PARALLEL_LLM=4

# ============================================================================
# OUTPUT ARTIFACTS
# ============================================================================
# Default: skip per-metric markdown (metric_*.json only). Executive brief uses JSON when
# EXECUTIVE_BRIEF_USE_JSON=true (default). Set false to write metric_*.md, or use CLI --write-metric-markdown.
# Tools that only read metric_*.md (e.g. weather context) need false here if you rely on them.
# DATA_ANALYST_SKIP_METRIC_MARKDOWN=true

# ============================================================================
# TEST MODE
# ============================================================================

# Set to "true" to use CSV data instead of Tableau A2A agents
# Useful for CI/CD and testing without external dependencies
DATA_ANALYST_TEST_MODE=false

# ============================================================================
# ANALYSIS ENGINE (Spec 008 — LLM-to-Code Refactor)
# ============================================================================

# Use code-based insight card generation instead of LLM for deterministic stages:
#   - StatisticalInsightCardGenerator (replaces StatisticalInsightsAgent LLM)
#   - HierarchyInsightCardAgent (replaces HierarchyVarianceRankerAgent LLM)
#   - DrillDownDecisionFunction (replaces DrillDownDecisionAgent LLM)
#   - AlertScoringPipeline (replaces AlertScoringCoordinator LLM)
#   - RuleBasedPlanner (replaces PlannerAgent LLM)
# Set to "false" to fall back to the original LLM-based path for any of the above.
USE_CODE_INSIGHTS=true

# Re-enable the legacy LLM-based alert extraction fallback (_llm_extract_alerts_from_text).
# Only needed if extract_alerts_from_analysis() fails to produce structured alerts.
# Default "false" — the structured JSON path is reliable and this fallback is not needed.
LEGACY_LLM_ALERT_EXTRACTION=false

# ============================================================================
# PHASE LOGGING CONFIGURATION
# ============================================================================

# Enable phase-based logging for each analysis phase
PHASE_LOGGING_ENABLED=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
PHASE_LOG_LEVEL=INFO

# Directory for phase log files (relative to project root)
PHASE_LOG_DIRECTORY=logs

# Save JSON summary after each cost center analysis
PHASE_LOG_SAVE_SUMMARY=true

# Log format: simple, detailed, json
PHASE_LOG_CONSOLE_FORMAT=detailed

# Track performance metrics for each phase
PHASE_LOG_TRACK_PERFORMANCE=true

# Log stack traces on errors
PHASE_LOG_STACK_TRACES=true

# ============================================================================
# EXECUTIVE BRIEF — HIERARCHICAL SCOPED BRIEFS (Spec 032)
# ============================================================================

# How many hierarchy levels to generate executive briefs for
# 0 = network only (current behavior)
# 1 = network + Level 1 entities (e.g. regions)
# 2 = network + Level 1 + Level 2 entities (e.g. regions + terminals)
EXECUTIVE_BRIEF_DRILL_LEVELS=0

# Cap per-entity briefs to hierarchy level N (1 = first drill e.g. region; 2 = second e.g. terminal).
# Omit to use legacy min(DRILL_LEVELS, 2). Use with max_drill_depth in contract for deep analysis
# without generating briefs at every hierarchy level.
# EXECUTIVE_BRIEF_MAX_SCOPED_LEVEL=1

# Maximum number of scoped briefs at Level 2 (terminals can be numerous)
EXECUTIVE_BRIEF_MAX_SCOPE_ENTITIES=10

# Cap total scoped briefs emitted across all hierarchy levels.
# Default in code is 20 (covers typical L1 regions without env). Set to 1 to save LLM time.
# EXECUTIVE_BRIEF_MAX_SCOPED_BRIEFS=20

# ============================================================================
# EXECUTIVE BRIEF — STYLE (CEO hybrid vs standard)
# ============================================================================
# `python -m data_analyst_agent` sets CEO by default (hybrid when JSON present).
# Use EXECUTIVE_BRIEF_STYLE=default or CLI --standard-brief for the legacy single-call brief.
# EXECUTIVE_BRIEF_STYLE=ceo

# ============================================================================
# EXECUTIVE BRIEF — CEO HYBRID PIPELINE (code rank -> 3.1 Flash-Lite -> 3.1 Pro)
# ============================================================================
# When EXECUTIVE_BRIEF_STYLE=ceo and metric JSON is available, the network
# brief uses Pass1 gemini-3.1-flash-lite-preview then Pass2 gemini-3.1-pro-preview.
# Scoped/drill-down briefs still use the digest + LLM path.
EXECUTIVE_BRIEF_USE_HYBRID_PIPELINE=true

# Optional overrides (defaults come from config/agent_models.yaml:
# executive_brief_hybrid_curator / executive_brief_hybrid_synthesis)
# EXECUTIVE_BRIEF_HYBRID_LITE_MODEL=gemini-3.1-flash-lite-preview
# EXECUTIVE_BRIEF_HYBRID_PRO_MODEL=gemini-3.1-pro-preview

# Pass 0 pool size sent to curation; Pass 1 keeps at most EXECUTIVE_BRIEF_HYBRID_MAX_CURATED.
EXECUTIVE_BRIEF_HYBRID_TOP_SIGNALS=30
EXECUTIVE_BRIEF_HYBRID_MAX_CURATED=12

# Set true to skip Flash-Lite curation (deterministic top-N only, then Pro).
EXECUTIVE_BRIEF_HYBRID_SKIP_CURATION=false

# ============================================================================
# EXECUTIVE BRIEF — OUTPUT FORMAT (Spec 033)
# ============================================================================

# Output format for executive briefs
# md   = markdown files only (legacy behavior)
# pdf  = markdown files + single combined PDF with bookmarks (default)
# both = alias for pdf
EXECUTIVE_BRIEF_OUTPUT_FORMAT=pdf

# ============================================================================
# REPORT SYNTHESIS / ALERT HARDENING
# ============================================================================

# Report synthesis execution mode: direct (default), llm (always try LLM first), auto.
REPORT_SYNTHESIS_EXECUTION_MODE=direct

# Cap on generate_markdown_report tool calls in report synthesis LLM path.
REPORT_SYNTHESIS_MAX_TOOL_CALLS=4

# Optional explicit direct-tool override for report synthesis.
REPORT_SYNTHESIS_FORCE_DIRECT_TOOL=false

# Drop anomalies when entity share-of-total is below this threshold.
ALERT_MATERIALITY_SHARE_MAX=0.001

# Non-ratio metrics: minimum absolute variance amount required to keep anomaly alert.
ALERT_MATERIALITY_MIN_VARIANCE_ABS=0

# Comma-separated entity names to suppress from anomaly extraction (case-insensitive).
# Keep empty to rely on dynamic runtime materiality filtering.
ALERT_SKIP_ITEM_NAMES=

# Ratio-like metrics only: suppress rows with extreme variance_pct but tiny absolute variance.
ALERT_SKIP_RATIO_EXTREME_PCT_MIN=200
ALERT_SKIP_RATIO_ABS_VARIANCE_MAX=0

# Skip narrative LLM when findings are below contract materiality thresholds.
SKIP_NARRATIVE_BELOW_MATERIALITY=true

# Narrative prompt budget caps.
NARRATIVE_MAX_ANALYST_CHARS=2000
NARRATIVE_MAX_STATS_CHARS=1500

# Emit per-target narrative payload/card audit JSON to outputs/debug/narrative_cards_audit/.
NARRATIVE_CARD_AUDIT_ENABLED=true
